            let actualHoursEarned = 0;

            trainingDays.forEach(day => {
                const dayState = remoteData[day.id] || { status: 'pending' };
                if (dayState.status === 'done') {
                    completedDays++;
                    actualHoursEarned += day.hours;
                }
            });

            const percent = Math.round((completedDays / trainingDays.length) * 100) || 0;
            document.getElementById('stat-progress-percent').innerText = percent + '%';
            document.getElementById('stat-progress-bar').style.width = percent + '%';
            document.getElementById('stat-days-count').innerText = completedDays + ' / ' + trainingDays.length + ' วัน';
