                tr.innerHTML = `
                    <td><strong>${item.date}</strong><br><span style="color:var(--text-muted); font-size:0.85rem;">${item.day}</span></td>
                    <td><span style="font-weight:500;">${item.time}</span><br>${item.hours > 0 ? `<span style="font-size:0.8rem; color:var(--text-muted);">(${item.hours} ชม.)</span>`:''}<br>${badgeHTML}</td>
                    <td><span class="phase-indicator">${item.phase}</span></td>
                    <td><input type="text" class="input-task" value="${userState.task || ''}" placeholder="ระบุเป้าหมาย..." onchange="sendToFirebase(${item.id}, 'task', this.value)"></td>
                    <td><textarea class="textarea-progress" rows="1" placeholder="พิมพ์สรุปผล..." onchange="sendToFirebase(${item.id}, 'progress', this.value)">${userState.progress || ''}</textarea></td>
                    <td>
                        <select class="select-status ${statusClass}" onchange="sendToFirebase(${item.id}, 'status', this.value)">
                            <option value="pending" class="status-pending" ${userState.status === 'pending' ? 'selected' : ''}>⏳ ยังไม่เริ่ม</option>
                            <option value="ongoing" class="status-ongoing" ${userState.status === 'ongoing' ? 'selected' : ''}>🔄 กำลังทำ</option>
                            <option value="done" class="status-done" ${userState.status === 'done' ? 'selected' : ''}>✅ สำเร็จแล้ว</option>
                        </select>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function sendToFirebase(id, field, value) {
            dbRef.child(id).update({ [field]: value });
        }
    </script>
</body>
</html>
