        :root {
            --primary: #059669;
            --primary-dark: #065f46;
            --primary-light: #d1fae5;
            --secondary: #10b981;
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --accent-study: #f97316;
            --accent-study-light: #fff7ed;
            --accent-comp: #3b82f6;
            --accent-comp-light: #eff6ff;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Sarabun', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            line-height: 1.6;
            padding-bottom: 60px;
        }
        h1, h2, h3, .heading-font { font-family: 'Chakra Petch', sans-serif; font-weight: 600; }

        header {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
            color: white;
            padding: 40px 20px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }
        header h1 { font-size: 2.2rem; margin-bottom: 8px; }
        .container { max-width: 1300px; margin: 0 auto; padding: 0 20px; }

        .dashboard-summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-top: -25px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            border: 1px solid var(--border);
        }
        .stat-card h3 { font-size: 0.95rem; color: var(--text-muted); margin-bottom: 10px; }
        .stat-card .value { font-size: 1.8rem; font-weight: 700; color: var(--primary-dark); font-family: 'Chakra Petch', sans-serif; }
        
        .progress-container { background-color: #e2e8f0; border-radius: 10px; height: 10px; width: 100%; margin-top: 10px; overflow: hidden; }
        .progress-bar { background-color: var(--secondary); height: 100%; width: 0%; transition: width 0.4s ease; }

        .table-container { background: var(--bg-card); border-radius: 12px; border: 1px solid var(--border); overflow: hidden; }
        .responsive-table { width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem; }
        .responsive-table th { background-color: #f1f5f9; padding: 14px 16px; border-bottom: 2px solid var(--border); font-family: 'Chakra Petch', sans-serif; }
        .responsive-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); vertical-align: top; }

        .row-weekend { background-color: #fafafa; }
        .row-study { background-color: var(--accent-study-light); }
        .row-special { background-color: var(--accent-comp-light); font-weight: 500; }

        .badge { display: inline-block; padding: 3px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; margin-top: 4px; }
        .badge-study { background-color: #ffedd5; color: #c2410c; }
        .badge-final { background-color: #fef08a; color: #854d0e; }
        .badge-travel { background-color: #dbeafe; color: #1d4ed8; }
        .badge-comp { background-color: #e0f2fe; color: #0369a1; }
        .phase-indicator { font-size: 0.75rem; color: var(--text-muted); background: #f1f5f9; padding: 2px 6px; border-radius: 4px; }

        .input-task, .textarea-progress {
            width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; font-family: 'Sarabun', sans-serif; font-size: 0.9rem; outline: none; background-color: #f8fafc;
        }
        .input-task:focus, .textarea-progress:focus { border-color: var(--secondary); background-color: #fff; }
        
        .select-status { padding: 6px 10px; border-radius: 6px; border: 1px solid var(--border); font-size: 0.85rem; font-weight: 500; width: 100%; cursor: pointer; }
        .status-pending { background-color: #f1f5f9; color: #475569; }
        .status-ongoing { background-color: #fef9c3; color: #a16207; }
        .status-done { background-color: #d1fae5; color: #065f46; border-color: #a7f3d0; }
        
        .live-indicator { display: inline-block; width: 10px; height: 10px; background-color: #22c55e; border-radius: 50%; animation: pulse 1.5s infinite; margin-right: 5px; }
        @keyframes pulse { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }
